# Docker image used by docker-compose.yml
APP_IMAGE=your-dockerhub-username/ccapp:latest

# Spring profile
SPRING_PROFILES_ACTIVE=dev

# Database (dev profile)
DEV_DB_URL=jdbc:mysql://your-rds-endpoint:3306/your_database
DEV_DB_USERNAME=your_db_username
DEV_DB_PASSWORD=your_db_password

# Database (prod profile, keep unset for dev/staging unless needed)
PROD_DB_URL=jdbc:mysql://your-rds-endpoint:3306/your_database
PROD_DB_USERNAME=your_db_username
PROD_DB_PASSWORD=your_db_password

# Redis
REDIS_HOST=redis

# JWT and encryption
JWT_SECRET=base64_encoded_jwt_secret
AES_KEY=base64_encoded_aes_key

# OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-api-domain/login/oauth2/code/google
KAKAO_CLIENT_ID=your_kakao_client_id
KAKAO_CLIENT_SECRET=your_kakao_client_secret

# KakaoPay
KAKAOPAY_SECRET_KEY=your_kakaopay_secret_key
KAKAOPAY_APPROVE_URL=https://your-api-domain/kakaoPay/approve
KAKAOPAY_CANCEL_URL=https://your-api-domain/kakaoPay/cancel
KAKAOPAY_FAIL_URL=https://your-api-domain/kakaoPay/fail

# AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=your_s3_bucket
AWS_BUCKET_DOMAIN=https://your-bucket-domain/

# Frontend and CORS
FRONTEND_BASE_URL=https://your-frontend-domain
CORS_ALLOWED_ORIGINS=https://your-frontend-domain,http://localhost:*

# Google Analytics
GA_SERVICE_ACCOUNT_KEY_BASE64=base64_encoded_ga_service_account_json
GA_PROPERTY_ID=your_ga_property_id

# Initial admin password
DEFAULT_PW=change_me
